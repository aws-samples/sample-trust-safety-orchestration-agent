# API Gateway endpoint (from SAM deploy output: RestApiUrl)
VITE_API_BASE_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/dev

# WebSocket endpoint (from SAM deploy output: WebSocketUrl)
VITE_WS_URL=wss://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/dev

# Leave both blank to run in demo mode (mock data, no backend needed)

